<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1914"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:outlineAmbientShadowColor="@android:color/transparent"
        android:outlineSpotShadowColor="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:titleTextAppearance="?attr/textAppearanceHeadlineSmall"
            app:titleTextColor="#E8DDD0"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="#D4A87C" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- User Interface Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:text="@string/settings_section_ui"
                android:textColor="#D4A87C"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <!-- Theme Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="?attr/materialCardViewFilledStyle"
                app:cardBackgroundColor="#2A2420"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="#E8DDD0"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="@string/settings_theme_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="#A89A8E" />

                    <!-- Theme Radio Group -->
                    <RadioGroup
                        android:id="@+id/radio_group_theme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Follow System -->
                        <RadioButton
                            android:id="@+id/radio_theme_system"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_system"
                            android:textColor="#E8DDD0"
                            android:padding="12dp"
                            android:background="?attr/selectableItemBackground"
                            android:buttonTint="#D4A87C" />

                        <!-- Light Theme -->
                        <RadioButton
                            android:id="@+id/radio_theme_light"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_light"
                            android:textColor="#E8DDD0"
                            android:padding="12dp"
                            android:background="?attr/selectableItemBackground"
                            android:buttonTint="#D4A87C" />

                        <!-- Dark Theme -->
                        <RadioButton
                            android:id="@+id/radio_theme_dark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_theme_dark"
                            android:textColor="#E8DDD0"
                            android:padding="12dp"
                            android:background="?attr/selectableItemBackground"
                            android:buttonTint="#D4A87C" />
                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Time Format Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="@string/settings_section_time"
                android:textColor="#D4A87C"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <!-- Time Format Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="?attr/materialCardViewFilledStyle"
                app:cardBackgroundColor="#2A2420"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_time_format"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="#E8DDD0"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="@string/settings_time_format_summary"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="#A89A8E" />

                    <!-- Time Format Radio Group -->
                    <RadioGroup
                        android:id="@+id/radio_group_time_format"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Relative Time -->
                        <RadioButton
                            android:id="@+id/radio_time_relative"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_time_relative"
                            android:textColor="#E8DDD0"
                            android:padding="12dp"
                            android:background="?attr/selectableItemBackground"
                            android:buttonTint="#D4A87C" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="36dp"
                            android:layout_marginBottom="8dp"
                            android:text="@string/settings_time_relative_summary"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="#A89A8E" />

                        <!-- Absolute Time -->
                        <RadioButton
                            android:id="@+id/radio_time_absolute"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_time_absolute"
                            android:textColor="#E8DDD0"
                            android:padding="12dp"
                            android:background="?attr/selectableItemBackground"
                            android:buttonTint="#D4A87C" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="36dp"
                            android:layout_marginBottom="8dp"
                            android:text="@string/settings_time_absolute_summary"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="#A89A8E" />
                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar (LogFox Style) -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#2A2420"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp">

        <!-- Main Button -->
        <LinearLayout
            android:id="@+id/btn_main"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#A89A8E"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="首页"
                android:textColor="#A89A8E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Service Button -->
        <LinearLayout
            android:id="@+id/btn_service"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#A89A8E"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="服务"
                android:textColor="#A89A8E"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Settings Button -->
        <LinearLayout
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="#D4A87C"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="设置"
                android:textColor="#D4A87C"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
